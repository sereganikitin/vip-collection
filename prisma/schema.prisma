generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  image        String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String
  logo     String?
  isActive Boolean   @default(true)
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  price       Float
  oldPrice    Float?
  images      String[]
  description String      @default("")
  specs       Json        @default("{}")
  inStock     Boolean     @default(true)
  isNew       Boolean     @default(false)
  isSale      Boolean     @default(false)
  isActive    Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  brandId     String
  brand       Brand       @relation(fields: [brandId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
}

model Order {
  id              String      @id @default(cuid())
  number          Int         @unique @default(autoincrement())
  status          OrderStatus @default(NEW)
  totalPrice      Float
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String?
  deliveryMethod  String?
  comment         String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Setting {
  key   String @id
  value String
}

model Banner {
  id          String  @id @default(cuid())
  image       String
  imageMobile String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  title       String?
  link        String?
}
