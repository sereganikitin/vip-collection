generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  image        String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String
  logo     String?
  isActive Boolean   @default(true)
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  price       Float
  oldPrice    Float?
  images      String[]
  description String      @default("")
  specs       Json        @default("{}")
  inStock     Boolean     @default(true)
  isNew       Boolean     @default(false)
  isSale      Boolean     @default(false)
  isActive    Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  brandId     String
  brand       Brand       @relation(fields: [brandId], references: [id])
  orderItems  OrderItem[]
  externalUrl String?     @unique
  noSync      Boolean     @default(false)
  lastSyncAt  DateTime?
  // Габариты для расчёта стоимости доставки. В см и кг. Если пусто —
  // используется дефолт категории (см. src/lib/delivery-defaults.ts).
  length      Float?      // см
  width       Float?      // см
  height      Float?      // см
  weight      Float?      // кг
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@index([externalUrl])
}

model Order {
  id              String      @id @default(cuid())
  number          Int         @unique @default(autoincrement())
  status          OrderStatus @default(NEW)
  totalPrice      Float
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String?
  deliveryMethod  String?
  comment         String?
  items           OrderItem[]
  paymentMethod   String      @default("cash")     // "cash" (при самовывозе) | "online" (через Тинькофф)
  paymentStatus   String      @default("pending")  // pending | paid | failed | refunded
  paymentId       String?                          // Тинькофф PaymentId
  paymentUrl      String?                          // Сохранённая ссылка на оплату (для повторного открытия)
  paidAt          DateTime?
  // Яндекс Доставка (заявки на курьерскую / интергородную доставку).
  // Заполняются при ручном создании заявки из админки.
  yandexClaimId        String?
  yandexClaimStatus    String?       // new, pickuped, delivered, cancelled, ...
  yandexClaimTariff    String?       // "courier" | "express" | "cargo" | "intercity" и т.п.
  yandexClaimPrice     Float?        // оценочная стоимость, RUB
  yandexClaimEta       String?       // ETA от Я.Доставки
  yandexClaimUrl       String?       // публичная трекинг-ссылка
  yandexClaimCreatedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Setting {
  key   String @id
  value String
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
}

model Banner {
  id          String  @id @default(cuid())
  image       String
  imageMobile String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  title       String?
  link        String?
}

// Контент статической страницы (доставка, о компании, ремонт, опт, самовывоз).
// Если строки нет — страница рендерится с дефолтным контентом
// из src/lib/page-defaults.ts (бекап-копия исходного хардкода).
model PageContent {
  slug      String   @id           // 'delivery' | 'about' | 'repair' | 'wholesale' | 'pickup'
  title     String                 // H1
  intro     String   @default("")  // markdown под H1
  sections  Json     @default("[]") // [{ icon?: string, title: string, body: string (markdown) }]
  body      String   @default("")  // markdown после sections
  faq       Json     @default("[]") // [{ q: string, a: string }]
  updatedAt DateTime @updatedAt
}
